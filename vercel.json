{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/**/*.js": { "maxDuration": 60 }
  },
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/connect/:platform", "destination": "/api/connect/platform?platform=:platform" },
    { "source": "/features", "destination": "/features.html" },
    { "source": "/pricing",  "destination": "/pricing.html"  },
    { "source": "/updates",  "destination": "/updates.html"  },
    { "source": "/about",    "destination": "/about.html"    },
    { "source": "/contact",  "destination": "/contact.html"  },
    { "source": "/privacy",  "destination": "/privacy.html"  },
    { "source": "/terms",    "destination": "/terms.html"    },
    { "source": "/admin",    "destination": "/admin.html"    },
    { "source": "/((?!api/|features|pricing|updates|about|contact|privacy|terms|admin).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/hourly", "schedule": "0 * * * *" }
  ]
}
