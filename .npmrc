# Pin npm's cache + global-prefix to E: so this project never causes the
# C: drive to fill up the way it did on 2026-05-30 (the disk-full failure
# that interrupted the Vite migration). The user-level ~/.npmrc has the
# same settings, but this project-local copy is portable — anyone who
# clones into a freshly-configured workstation gets the same behaviour
# without having to know about it.
#
# Cache: pure read/write storage of downloaded tarballs. Safe to delete
#        wholesale; npm will repopulate.
# Prefix: where `npm install -g <pkg>` lands the binaries (e.g. Vercel CLI).
#         The new bin dir needs to be in PATH for the shims to be callable.
cache=E:/npm-cache
prefix=E:/npm-global
