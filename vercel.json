{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/**/*.js": { "maxDuration": 60 }
  },
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/connect/:platform", "destination": "/api/connect/platform?platform=:platform" },
    { "source": "/features",              "destination": "/features.html"            },
    { "source": "/integrations",          "destination": "/integrations.html"        },
    { "source": "/pricing",               "destination": "/pricing.html"             },
    { "source": "/updates",               "destination": "/updates.html"             },
    { "source": "/about",                 "destination": "/about.html"               },
    { "source": "/contact",               "destination": "/contact.html"             },
    { "source": "/privacy",               "destination": "/privacy.html"             },
    { "source": "/terms",                 "destination": "/terms.html"               },
    { "source": "/stack",                 "destination": "/stack.html"               },
    { "source": "/compare",               "destination": "/compare.html"             },
    { "source": "/compare/buffer",        "destination": "/compare-buffer.html"      },
    { "source": "/compare/later",         "destination": "/compare-later.html"       },
    { "source": "/compare/metricool",     "destination": "/compare-metricool.html"   },
    { "source": "/compare/sprout-social", "destination": "/compare-sprout-social.html" },
    { "source": "/compare/hootsuite",     "destination": "/compare-hootsuite.html"   },
    { "source": "/compare/rival-iq",      "destination": "/compare-rival-iq.html"    },
    { "source": "/admin",                 "destination": "/admin.html"               },
    { "source": "/((?!api/|features|integrations|pricing|updates|about|contact|privacy|terms|stack|compare|admin).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/hourly", "schedule": "0 * * * *" }
  ]
}
